generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Asegurado {
  id              String   @id @default(cuid())
  nombre          String
  cedula          String   @unique
  polizaId        String   @unique
  fechaNacimiento DateTime?
  telefono        String?
  email           String?
  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt

  poliza  Poliza?
  alertas Alerta[]
}

model Poliza {
  id                 String       @id @default(cuid())
  polizaId           String       @unique
  cedulaAsegurado    String
  fechaInicio        DateTime
  fechaFin           DateTime
  estado             String
  cobertura          String
  preExistencias     String?
  gestorAsignado     String?
  gestorEmail        String?
  creadoEn           DateTime     @default(now())
  actualizadoEn      DateTime     @updatedAt

  asegurado Asegurado @relation(fields: [polizaId], references: [polizaId], onDelete: Restrict, onUpdate: Cascade)
}

model Alerta {
  id                    String       @id @default(cuid())
  nombre                String
  cedulaPaciente        String
  polizaId              String
  fechaIngreso          DateTime     @default(now())
  estadoPoliza          String
  preExistencias        String?
  notificacionEnviada   Boolean      @default(false)
  gestorAsignado        String?
  hospital              String
  notionSyncId          String?
  resumenIA             String?
  creadoEn              DateTime     @default(now())
  actualizadoEn         DateTime     @updatedAt

  asegurado Asegurado @relation(fields: [cedulaPaciente], references: [cedula], onDelete: Restrict, onUpdate: Cascade)

  @@index([cedulaPaciente])
  @@index([fechaIngreso])
}

model Configuracion {
  id                   String   @id @default(cuid())
  registrosPorPagina    Int      @default(10)
  formatoFecha          String   @default("DD/MM/YYYY")
  formatoHora           String   @default("12h")
  institucionNombre     String   @default("Hospital Central")
  institucionDireccion  String   @default("")
  institucionTelefono   String   @default("")
  institucionCorreo     String   @default("")
  validacionAutomatica  Boolean  @default(true)
  cierreAutomaticoCasos Boolean  @default(true)
  actualizadoEn         DateTime @updatedAt
  creadoEn              DateTime @default(now())
}
