# ════════════════════════════════════════════════════════════════
#  MEDIX — Variables de Entorno Unificadas
#  Copia este archivo como .env en la raíz del proyecto
#  En Render: pega estas variables en Dashboard > Environment
# ════════════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────────
# Render inyecta PORT automáticamente (10000). No cambies esto.
PORT=4000
NODE_ENV=production

# URL pública de tu servicio en Render (sin barra al final)
# Ejemplo: https://medix-abc123.onrender.com
FRONTEND_URL=https://TU-SERVICIO.onrender.com

# ── Next.js (Frontend) ────────────────────────────────────────
# En producción apunta al mismo dominio ya que todo es un servicio
NEXT_PUBLIC_API_URL=https://TU-SERVICIO.onrender.com

# ── Base de Datos ─────────────────────────────────────────────
DATABASE_URL=file:./BackEnd/prisma/dev.db

# ── Notion ───────────────────────────────────────────────────
NOTION_TOKEN=
NOTION_ASEGURADOS_DB_ID=
NOTION_POLIZAS_DB_ID=
NOTION_ALERTAS_DB_ID=

# ── Inteligencia Artificial ───────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
DESTINATION_HOSPITAL=hospital_demo@yopmail.com
DESTINATION_INSURANCE=seguro_demo@yopmail.com
